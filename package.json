{
  "name": "xenforo-markdown",
  "version": "1.2.0",
  "description": "Simple alternative implementation of Markdown in XenForo",
  "main": "xf-markdown.ts",
  "scripts": {
    "build": "node ./build.mjs && lessc ./src/markdown.less --clean-css='--s1 --advanced --compatibility=*' > dist/markdown.min.css",
    "watch": "node ./watch.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/McShare/xenforo-markdown.git"
  },
  "keywords": [
    "markdown",
    "xenforo"
  ],
  "author": "Subilan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/McShare/xenforo-markdown/issues"
  },
  "homepage": "https://github.com/McShare/xenforo-markdown#readme",
  "dependencies": {
    "jquery": "^3.6.0",
    "less-plugin-clean-css": "^1.6.0",
    "lessc": "^1.0.2",
    "markdown-it": "^14.1.0",
    "prismjs": "^1.27.0",
    "remove-markdown": "^0.6.3",
    "xss": "^1.0.11"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.3.0",
    "@types/prismjs": "^1.26.0",
    "@types/underscore": "^1.11.4",
    "esbuild": "0.14.54",
    "typescript": "^5.9.3",
    "uglify-js": "^3.15.3"
  }
}
