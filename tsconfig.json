{
  "compilerOptions": {
    "target": "ES2015",
    "module": "es2015", 
    "moduleResolution": "bundler", 
    "lib": ["ES2016", "DOM"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
